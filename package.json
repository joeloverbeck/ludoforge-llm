{
  "name": "ludoforge-llm",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "check:ticket-deps": "node scripts/check-ticket-deps.mjs",
    "guard:worktree-pointers": "node scripts/check-worktree-pointers.mjs",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "pnpm run check:ticket-deps && turbo test",
    "test:engine:unit": "pnpm -F @ludoforge/engine test:unit",
    "test:engine:integration": "pnpm -F @ludoforge/engine test:integration",
    "test:engine:integration:core": "pnpm -F @ludoforge/engine test:integration:core",
    "test:engine:game-packages": "pnpm -F @ludoforge/engine test:integration:game-packages",
    "test:engine:performance": "pnpm -F @ludoforge/engine test:performance",
    "test:engine:memory": "pnpm -F @ludoforge/engine test:memory",
    "scan:fitl:policy": "node scripts/fitl-policy-seed-scan.mjs",
    "dev": "turbo dev",
    "schema:artifacts": "turbo schema:artifacts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "turbo": "^2.8.20",
    "typescript-eslint": "^8.57.1"
  }
}
