{
  "name": "@ludoforge/engine",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/src/kernel/index.d.ts",
      "import": "./dist/src/kernel/index.js"
    },
    "./runtime": {
      "types": "./dist/src/kernel/runtime.d.ts",
      "import": "./dist/src/kernel/runtime.js"
    },
    "./cnl": {
      "types": "./dist/src/cnl/index.d.ts",
      "import": "./dist/src/cnl/index.js"
    },
    "./agents": {
      "types": "./dist/src/agents/index.d.ts",
      "import": "./dist/src/agents/index.js"
    },
    "./sim": {
      "types": "./dist/src/sim/index.d.ts",
      "import": "./dist/src/sim/index.js"
    },
    "./trace": {
      "types": "./dist/src/trace/index.d.ts",
      "import": "./dist/src/trace/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/run-with-dist-lock.mjs \"pnpm run clean && tsc\"",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "schema:artifacts": "node scripts/run-with-dist-lock.mjs \"node scripts/schema-artifacts.mjs\"",
    "schema:artifacts:check": "node scripts/schema-artifacts.mjs --check",
    "test:unit": "node --test \"dist/test/unit/**/*.test.js\"",
    "test:integration": "node scripts/run-tests.mjs --lane integration",
    "test:integration:core": "node scripts/run-tests.mjs --lane integration:core",
    "test:integration:game-packages": "node scripts/run-tests.mjs --lane integration:game-packages",
    "test:performance": "node --test \"dist/test/performance/**/*.test.js\"",
    "test:memory": "node --test \"dist/test/memory/**/*.test.js\"",
    "test:e2e": "node scripts/run-tests.mjs --lane e2e",
    "test:e2e:slow": "RUN_SLOW_E2E=1 node scripts/run-tests.mjs --lane e2e:slow",
    "test:e2e:mcts": "RUN_MCTS_E2E=1 node scripts/run-tests.mjs --lane e2e:mcts",
    "test:e2e:mcts:fast": "RUN_MCTS_E2E=1 node scripts/run-tests.mjs --lane e2e:mcts:fast",
    "test:e2e:mcts:default": "RUN_MCTS_E2E=1 node scripts/run-tests.mjs --lane e2e:mcts:default",
    "test:e2e:mcts:strong": "RUN_MCTS_E2E=1 node scripts/run-tests.mjs --lane e2e:mcts:strong",
    "test:e2e:mcts:fitl": "RUN_MCTS_FITL_E2E=1 node scripts/run-tests.mjs --lane e2e:mcts:fitl",
    "test:e2e:mcts:fitl:fast": "RUN_MCTS_FITL_E2E=1 node scripts/run-tests.mjs --lane e2e:mcts:fitl:fast",
    "test:e2e:mcts:fitl:default": "RUN_MCTS_FITL_E2E=1 node scripts/run-tests.mjs --lane e2e:mcts:fitl:default",
    "test:e2e:mcts:fitl:strong": "RUN_MCTS_FITL_E2E=1 node scripts/run-tests.mjs --lane e2e:mcts:fitl:strong",
    "test:e2e:all": "RUN_SLOW_E2E=1 node scripts/run-tests.mjs --lane e2e",
    "test": "pnpm run schema:artifacts:check && node scripts/run-tests.mjs --lane default",
    "test:all": "node scripts/run-tests.mjs \"dist/test/unit/**/*.test.js\" \"dist/test/integration/**/*.test.js\" \"dist/test/performance/**/*.test.js\" \"dist/test/memory/**/*.test.js\" \"dist/test/e2e/**/*.test.js\""
  },
  "dependencies": {
    "yaml": "^2.8.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "ajv": "^8.17.1",
    "typescript": "^5.9.2"
  }
}
