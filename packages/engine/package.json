{
  "name": "@ludoforge/engine",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/src/kernel/index.d.ts",
      "import": "./dist/src/kernel/index.js"
    },
    "./runtime": {
      "types": "./dist/src/kernel/runtime.d.ts",
      "import": "./dist/src/kernel/runtime.js"
    },
    "./cnl": {
      "types": "./dist/src/cnl/index.d.ts",
      "import": "./dist/src/cnl/index.js"
    },
    "./agents": {
      "types": "./dist/src/agents/index.d.ts",
      "import": "./dist/src/agents/index.js"
    },
    "./sim": {
      "types": "./dist/src/sim/index.d.ts",
      "import": "./dist/src/sim/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/run-with-dist-lock.mjs \"pnpm run clean && tsc\"",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "schema:artifacts": "node scripts/run-with-dist-lock.mjs \"node scripts/schema-artifacts.mjs\"",
    "schema:artifacts:check": "node scripts/run-with-dist-lock.mjs \"node scripts/schema-artifacts.mjs --check\"",
    "test:unit": "node scripts/run-with-dist-lock.mjs \"node --test \\\"dist/test/unit/**/*.test.js\\\"\"",
    "test:integration": "node scripts/run-with-dist-lock.mjs \"node --test \\\"dist/test/integration/**/*.test.js\\\"\"",
    "test:performance": "node scripts/run-with-dist-lock.mjs \"node --test \\\"dist/test/performance/**/*.test.js\\\"\"",
    "test:memory": "node scripts/run-with-dist-lock.mjs \"node --test \\\"dist/test/memory/**/*.test.js\\\"\"",
    "test:e2e": "node scripts/run-with-dist-lock.mjs \"node --test \\\"dist/test/e2e/**/*.test.js\\\"\"",
    "test:e2e:slow": "node scripts/run-with-dist-lock.mjs \"RUN_SLOW_E2E=1 node --test \\\"dist/test/e2e/texas-holdem-tournament.test.js\\\" \\\"dist/test/e2e/texas-holdem-card-lifecycle.test.js\\\"\"",
    "test:e2e:all": "node scripts/run-with-dist-lock.mjs \"RUN_SLOW_E2E=1 node --test \\\"dist/test/e2e/**/*.test.js\\\"\"",
    "test": "node scripts/run-with-dist-lock.mjs \"pnpm run schema:artifacts:check && node scripts/run-tests.mjs\"",
    "test:all": "node scripts/run-with-dist-lock.mjs \"node scripts/run-tests.mjs \\\"dist/test/unit/**/*.test.js\\\" \\\"dist/test/integration/**/*.test.js\\\" \\\"dist/test/performance/**/*.test.js\\\" \\\"dist/test/memory/**/*.test.js\\\" \\\"dist/test/e2e/**/*.test.js\\\"\""
  },
  "dependencies": {
    "yaml": "^2.8.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "ajv": "^8.17.1",
    "typescript": "^5.9.2"
  }
}
