{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "gameDefId": {
      "type": "string"
    },
    "runCount": {
      "type": "number"
    },
    "metrics": {
      "type": "object",
      "properties": {
        "avgGameLength": {
          "type": "number"
        },
        "avgBranchingFactor": {
          "type": "number"
        },
        "actionDiversity": {
          "type": "number"
        },
        "resourceTension": {
          "type": "number"
        },
        "interactionProxy": {
          "type": "number"
        },
        "dominantActionFreq": {
          "type": "number"
        },
        "dramaMeasure": {
          "type": "number"
        }
      },
      "required": [
        "avgGameLength",
        "avgBranchingFactor",
        "actionDiversity",
        "resourceTension",
        "interactionProxy",
        "dominantActionFreq",
        "dramaMeasure"
      ],
      "additionalProperties": false
    },
    "degeneracyFlags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "LOOP_DETECTED",
          "NO_LEGAL_MOVES",
          "DOMINANT_ACTION",
          "TRIVIAL_WIN",
          "STALL",
          "TRIGGER_DEPTH_EXCEEDED"
        ]
      }
    },
    "perSeed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "seed": {
            "type": "number"
          },
          "turnCount": {
            "type": "number"
          },
          "stopReason": {
            "anyOf": [
              {
                "type": "string",
                "const": "terminal"
              },
              {
                "type": "string",
                "const": "maxTurns"
              },
              {
                "type": "string",
                "const": "noLegalMoves"
              }
            ]
          },
          "metrics": {
            "type": "object",
            "properties": {
              "gameLength": {
                "type": "number"
              },
              "avgBranchingFactor": {
                "type": "number"
              },
              "actionDiversity": {
                "type": "number"
              },
              "resourceTension": {
                "type": "number"
              },
              "interactionProxy": {
                "type": "number"
              },
              "dominantActionFreq": {
                "type": "number"
              },
              "dramaMeasure": {
                "type": "number"
              }
            },
            "required": [
              "gameLength",
              "avgBranchingFactor",
              "actionDiversity",
              "resourceTension",
              "interactionProxy",
              "dominantActionFreq",
              "dramaMeasure"
            ],
            "additionalProperties": false
          },
          "degeneracyFlags": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "LOOP_DETECTED",
                "NO_LEGAL_MOVES",
                "DOMINANT_ACTION",
                "TRIVIAL_WIN",
                "STALL",
                "TRIGGER_DEPTH_EXCEEDED"
              ]
            }
          }
        },
        "required": [
          "seed",
          "turnCount",
          "stopReason",
          "metrics",
          "degeneracyFlags"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "gameDefId",
    "runCount",
    "metrics",
    "degeneracyFlags",
    "perSeed"
  ],
  "additionalProperties": false,
  "$id": "EvalReport.schema.json"
}
